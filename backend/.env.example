# =============================================
# ПРИМЕР .env — скопируй в .env и заполни
# =============================================

# PostgreSQL в production (Render)
# Для локальной разработки можно использовать SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./komuz.db
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/komuz_ai

# JWT секрет — минимум 32 символа, сгенерируй: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this

# AI режим: true = mock WAV (Фаза 1), false = реальный HF Spaces (Фаза 2)
USE_MOCK_AI=true

# URL бэкенда для ссылок на аудио файлы (mock режим)
BACKEND_URL=http://localhost:8000

# Hugging Face Spaces (нужен только при USE_MOCK_AI=false)
HF_SPACE_URL=https://your-username-komuz-music.hf.space

# Cloudinary (для хранения аудио в production)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
